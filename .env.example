# Copy to .env and fill in real values. Never commit the real .env file.
# `chmod 600 .env` on the server — it holds real secrets.

# --- Deployment mode ---
# "production" makes the app refuse to start with insecure defaults (default JWT_SECRET,
# missing SIGNUP_INVITE_CODE) — see app/core/config.py:assert_secure_for_production.
# Leave as "development" for local work.
APP_ENV=production

# --- Reverse proxy / TLS (docker-compose's caddy service + ./Caddyfile) ---
# Real public domain pointing at this server, so Caddy can get a Let's Encrypt cert.
# Leave as "localhost" for local Docker Compose testing (self-signed cert, browser warning).
DOMAIN=your-domain.example.com

# --- Database ---
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=change-me-to-a-long-random-string
# Only used outside docker-compose (e.g. running the backend directly against a local Postgres);
# docker-compose.yml builds this itself from POSTGRES_PASSWORD for the backend service.
DATABASE_URL=postgresql+psycopg2://newsatlas:${POSTGRES_PASSWORD}@localhost:5432/newsatlas

# --- Auth ---
# Generate with: openssl rand -hex 32  (must be >= 32 chars; enforced in production, see above)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_MINUTES=1440
# Required for anyone to be able to create an account (fails closed if unset — see
# app/api/auth.py). Share this out-of-band with teammates you want to invite; rotate it
# by changing this value if it ever leaks.
SIGNUP_INVITE_CODE=

# Generate with: openssl rand -hex 32  (must be >= 32 chars; enforced in production, see above)
# Encrypts the Mistral/NewsData.io API keys at rest in workspace_settings (see
# app/core/crypto.py) — changing this after keys have been saved makes them
# undecryptable, so treat it like JWT_SECRET: generate it once, keep it safe.
APP_SECRET_KEY=change-me-to-a-long-random-string

# --- News ingestion ---
# NewsAPI.org is the original source; env var is only the bootstrap default (an admin
# can enable/disable it and set its rate limit from Settings > News sources).
NEWSAPI_API_KEY=
# Google News RSS needs no API key at all (off by default; enable in Settings) and
# NewsData.io is a second paid source (also off by default) whose key can be set here
# as a fallback or, like Mistral's key, overridden in-app from Settings > News sources.
NEWSDATA_API_KEY=

# --- AI summarization ---
# All MISTRAL_* variables below are bootstrap defaults only. Once the app is running, an
# admin can view and override every one of them (including the API key) from the in-app
# Company profile > AI configuration settings — the database value wins once set. These
# env vars just seed the initial workspace_settings row (and remain the fallback for the
# API key specifically, if no in-app override has ever been set).
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
# Cheap model used to triage articles (worth summarizing? yes/no) before the full
# mistral-large call — cuts spend by skipping low-value articles early. Set
# MISTRAL_TRIAGE_ENABLED=false to disable and send everything straight to MISTRAL_MODEL.
MISTRAL_TRIAGE_MODEL=mistral-small-latest
MISTRAL_TRIAGE_ENABLED=true
# Embedding model used to detect near-duplicate articles (same story, different outlet)
# for the same target company before spending a summarization call on either.
MISTRAL_EMBED_MODEL=mistral-embed
# Cosine similarity (0-1) above which a new article is treated as a duplicate of an
# existing one. Lower = more aggressive deduping; raise if distinct stories get merged.
MISTRAL_DEDUPE_SIMILARITY_THRESHOLD=0.90
# Unlike the vars above, these two are read directly (not bootstrapped into
# workspace_settings / not admin-editable in-app) — they cap outbound request pacing to
# Mistral so ingestion never gets 429'd. Mistral exposes no remaining-quota header, so
# MISTRAL_MAX_REQUESTS_PER_SECOND must be set at or below your account's actual tier
# limit (Mistral Admin Console > Limits); the default is a safe value for the free tier.
MISTRAL_MAX_REQUESTS_PER_SECOND=1
# Retries per HTTP call (not per article) on 429/5xx/network errors, with exponential
# backoff honoring Mistral's Retry-After header when present.
MISTRAL_MAX_RETRIES=5

# --- Email digest (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=signals@example.com

# --- Scheduling defaults (can be overridden per-workspace in Settings) ---
INGESTION_INTERVAL_HOURS=6
DIGEST_SEND_TIME=07:00
# Set to false to disable the background scheduler (e.g. in tests)
ENABLE_SCHEDULER=true
# Minimum seconds between manual "run now" triggers for ingestion/digest, regardless of
# which user calls them — protects against runaway NewsAPI/Mistral/SMTP usage.
MANUAL_TRIGGER_COOLDOWN_SECONDS=60

# --- Rate limiting ---
# Set to false only for automated tests; keep true everywhere else.
ENABLE_RATE_LIMITING=true

# --- CORS ---
# Only needed if the frontend is served from a different origin than the API (the default
# Caddy setup serves both from one origin, so same-origin requests don't need this at all).
CORS_ORIGINS=["https://your-domain.example.com"]

# --- Used to build links back to the dashboard from digest emails ---
FRONTEND_BASE_URL=https://your-domain.example.com

# --- Frontend build (only needed if NOT using the default same-origin Caddy setup) ---
# VITE_API_BASE_URL=/api
