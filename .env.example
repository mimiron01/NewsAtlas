# Copy to .env and fill in real values. Never commit the real .env file.

# --- Database (used by backend; docker-compose overrides this to point at the db service) ---
DATABASE_URL=postgresql+psycopg2://newsatlas:newsatlas@localhost:5432/newsatlas

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_MINUTES=10080

# --- News ingestion ---
NEWSAPI_API_KEY=

# --- AI summarization ---
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# --- Email digest (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=signals@example.com

# --- Scheduling defaults (can be overridden per-workspace in Settings) ---
INGESTION_INTERVAL_HOURS=6
DIGEST_SEND_TIME=07:00
# Set to false to disable the background scheduler (e.g. in tests)
ENABLE_SCHEDULER=true

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ORIGINS=["http://localhost:5173"]

# --- Used to build links back to the dashboard from digest emails ---
FRONTEND_BASE_URL=http://localhost:5173
